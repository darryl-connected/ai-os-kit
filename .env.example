# =============================================================================
# AIS-OS Kit — Environment variables template
# =============================================================================
# Copy this file to .env and fill in real values. Never commit .env.
# Scripts read these via os.environ.get("VARNAME") or python-dotenv.
# =============================================================================

# ---------- Google Workspace (one OAuth flow covers Calendar, Gmail, Drive) ----------
# See scripts/google_auth.py for setup instructions.
# Place credentials.json (OAuth client ID) at the vault root, then run any
# Google script once to generate token.pickle.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.pickle
# Default Drive folder for uploads (create a "Sandbox" folder, get its ID from URL)
GOOGLE_DRIVE_DEFAULT_FOLDER_ID=

# ---------- Fathom ----------
# Settings → API → Generate key. Real value lives in your password manager.
FATHOM_API_KEY=
# Optional: default webhook for push delivery (not used yet)
FATHOM_WEBHOOK_URL=

# ---------- ClickUp ----------
# Settings → Apps → API Token
CLICKUP_API_TOKEN=
# Workspace ID (from URL when you're in the workspace)
CLICKUP_WORKSPACE_ID=

# ---------- Figma ----------
# Settings → Personal Access Tokens
FIGMA_ACCESS_TOKEN=
# File key from Figma URL (the alphanumeric segment after /figma.com/file/)
FIGMA_DEFAULT_FILE_KEY=

# ---------- Optional: Push to Drive ----------
# Override the default folder for push_to_drive.py if different from GOOGLE_DRIVE_DEFAULT_FOLDER_ID
PUSH_TO_DRIVE_FOLDER_ID=